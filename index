<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Commission & Allocation v4 · OTB Solutions</title>
<style>
:root{--navy:#002D72;--navy-deep:#001F52;--navy-soft:#E8EEF7;--orange:#F37321;--orange-soft:#FFE8D6;--ink:#1A1A1A;--ink-dim:#535353;--ink-soft:#8A8478;--line:#E2E2E2;--line-soft:#F1F1F1;--bg:#F8F6F1;--surface:#FFFFFF;--surface-warm:#FBF9F4;--green:#16A34A;--green-soft:#DCFCE7;--red:#DC2626;--red-soft:#FEE2E2;--amber:#D97706;--amber-soft:#FEF3C7;--purple:#5A4F75;--purple-soft:#ECE9F1;--teal:#0E7490;--teal-soft:#CFFAFE;--r-sm:6px;--r-md:10px;--r-lg:14px;--shadow-sm:0 1px 2px rgba(0,0,0,.04);--shadow-md:0 1px 3px rgba(0,0,0,.06),0 4px 12px rgba(0,0,0,.05);--font:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;--mono:ui-monospace,'SF Mono','JetBrains Mono',Consolas,monospace}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:var(--font);background:var(--bg);color:var(--ink);font-size:14px;line-height:1.5;-webkit-font-smoothing:antialiased;padding:24px 16px 80px}
.wrap{max-width:1200px;margin:0 auto}

.header{background:linear-gradient(135deg,var(--navy) 0%,#003D8F 100%);color:#fff;border-radius:var(--r-lg);padding:24px 28px;margin-bottom:18px;box-shadow:var(--shadow-md)}
.header .eye{font-size:11px;letter-spacing:1.8px;text-transform:uppercase;color:var(--orange);font-weight:700;margin-bottom:6px}
.header h1{font-size:24px;letter-spacing:-0.6px;font-weight:800;margin-bottom:4px}
.header p{font-size:13px;opacity:0.85}

.section{background:var(--surface);border:1px solid var(--line);border-radius:var(--r-lg);padding:20px 24px;margin-bottom:14px;box-shadow:var(--shadow-sm)}
.section-title{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid var(--line-soft);flex-wrap:wrap;gap:8px}
.section-title h2{font-size:14px;font-weight:700;color:var(--navy);letter-spacing:0.3px;text-transform:uppercase}
.section-title .subtotal{font-family:var(--mono);font-size:15px;font-weight:700;color:var(--ink)}
.section-title .subtotal .lbl{font-family:var(--font);font-size:11px;color:var(--ink-soft);text-transform:uppercase;letter-spacing:1px;margin-right:8px;font-weight:600}
.muted-help{font-size:12px;color:var(--ink-dim);line-height:1.5}

/* Generic picker cards */
.picker-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:6px}
.pick-card{border:2px solid var(--line);background:var(--surface-warm);border-radius:var(--r-md);padding:14px 16px;cursor:pointer;transition:all .15s;text-align:left;font-family:var(--font)}
.pick-card:hover{border-color:var(--navy-soft)}
.pick-card.active{border-color:var(--navy);background:var(--navy-soft);box-shadow:var(--shadow-sm)}
.pick-card.scn-op.active{border-color:var(--orange);background:var(--orange-soft)}
.pick-card .pc-eye{font-size:10px;text-transform:uppercase;letter-spacing:1.5px;color:var(--orange);font-weight:700;margin-bottom:4px}
.pick-card.scn-op.active .pc-eye{color:var(--navy-deep)}
.pick-card .pc-ttl{font-size:15px;font-weight:800;color:var(--ink);margin-bottom:4px;letter-spacing:-0.2px}
.pick-card .pc-dsc{font-size:12px;color:var(--ink-dim);line-height:1.4}

/* Scenario pills (product) */
.pills{display:flex;gap:8px;flex-wrap:wrap}
.pill{padding:8px 14px;border:1px solid var(--line);background:var(--surface);border-radius:999px;font-size:12px;font-weight:700;color:var(--ink-dim);cursor:pointer;transition:all .15s;font-family:var(--font)}
.pill:hover{border-color:var(--orange);color:var(--orange);transform:translateY(-1px)}
.pill.active{background:var(--orange);color:#fff;border-color:var(--orange)}

/* Account */
.account-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.account-field{display:flex;flex-direction:column;gap:4px}
.account-field label{font-size:11px;color:var(--ink-soft);text-transform:uppercase;letter-spacing:1px;font-weight:600}
.account-field .computed-display{padding:7px 10px;background:var(--navy-soft);border-radius:var(--r-sm);font-family:var(--mono);font-size:13px;font-weight:700;color:var(--navy);text-align:right}

/* Simple row */
.row{display:grid;grid-template-columns:1fr 130px 170px;align-items:center;gap:12px;padding:8px 0;border-bottom:1px solid var(--line-soft)}
.row:last-child{border-bottom:none}
.row .lbl{font-weight:600}
.row .sub{font-size:12px;color:var(--ink-soft)}
.row .lbl-wrap{display:flex;flex-direction:column;gap:2px}

input[type=number]{width:100%;padding:7px 10px;border:1px solid var(--line);border-radius:var(--r-sm);font-family:var(--mono);font-size:13px;text-align:right;background:var(--surface);color:var(--ink);transition:border .15s,box-shadow .15s}
input[type=number]:focus{outline:none;border-color:var(--navy);box-shadow:0 0 0 3px var(--navy-soft)}
.input-prefix{display:flex;align-items:center;border:1px solid var(--line);border-radius:var(--r-sm);background:var(--surface);transition:border .15s,box-shadow .15s}
.input-prefix:focus-within{border-color:var(--navy);box-shadow:0 0 0 3px var(--navy-soft)}
.input-prefix .pfx{padding:0 6px 0 10px;color:var(--ink-soft);font-family:var(--mono);font-size:12px;flex-shrink:0}
.input-prefix .sfx{padding:0 10px 0 4px;color:var(--ink-soft);font-family:var(--mono);font-size:12px;flex-shrink:0}
.input-prefix input{border:none;padding:7px 6px 7px 0;background:transparent;flex:1;min-width:0}
.input-prefix input:focus{box-shadow:none}

.computed{font-family:var(--mono);font-size:14px;font-weight:700;text-align:right;color:var(--ink);padding:7px 10px;background:var(--surface-warm);border-radius:var(--r-sm);border:1px solid var(--line-soft)}
.computed.zero{color:var(--ink-soft);font-weight:500}
.computed .yr{display:block;font-size:10px;font-weight:500;color:var(--ink-soft);margin-top:1px}

/* PEPM tier ribbon */
.pepm-tier{margin-top:10px;padding:10px 14px;background:var(--navy-soft);border-radius:var(--r-md);font-size:12px;color:var(--navy-deep)}
.pepm-tier .ttl{font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:1px;color:var(--navy);margin-bottom:6px}
.pepm-tier .bar{display:flex;height:24px;border-radius:var(--r-sm);overflow:hidden;background:#FFF;border:1px solid var(--line)}
.pepm-tier .bar > div{display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;font-family:var(--mono);min-width:0;padding:0 6px;white-space:nowrap;overflow:hidden}
.pepm-tier .bar .tpa{background:var(--teal)}
.pepm-tier .bar .fmo{background:var(--orange)}
.pepm-tier .bar .broker{background:var(--purple)}
.pepm-tier .bar .empty{background:#F3F3F3;color:var(--ink-soft)}
.pepm-tier .legend{margin-top:6px;font-size:11px;color:var(--ink-dim);display:flex;gap:14px;flex-wrap:wrap}
.pepm-tier .legend span::before{content:'';display:inline-block;width:10px;height:10px;border-radius:2px;margin-right:5px;vertical-align:middle}
.pepm-tier .legend .L-tpa::before{background:var(--teal)}
.pepm-tier .legend .L-fmo::before{background:var(--orange)}
.pepm-tier .legend .L-broker::before{background:var(--purple)}

/* BL package selector */
.bl-bar{display:flex;align-items:center;gap:10px;margin:14px 0 10px;padding:10px 14px;background:var(--purple-soft);border-radius:var(--r-md);flex-wrap:wrap}
.bl-bar .bl-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--purple)}
.bl-pills{display:flex;gap:6px}
.bl-pill{padding:6px 12px;border:1px solid var(--purple);background:var(--surface);color:var(--purple);border-radius:999px;font-size:12px;font-weight:700;cursor:pointer;transition:all .12s;font-family:var(--font)}
.bl-pill:hover{background:var(--purple-soft)}
.bl-pill.active{background:var(--purple);color:#fff}
.bl-bar .bl-meta{font-size:11px;color:var(--ink-dim);flex:1;min-width:160px}

/* FMO override row */
.fmo-row{display:grid;grid-template-columns:1fr 110px 110px 170px;align-items:center;gap:12px;padding:10px 12px;background:var(--orange-soft);border:1px solid var(--orange);border-radius:var(--r-md);margin-top:10px}
.fmo-row .lbl{font-weight:700;color:var(--ink)}
.fmo-row .sub{font-size:11px;color:var(--ink-dim)}

/* Products */
.prods-wrap{overflow-x:auto;border:1px solid var(--line);border-radius:var(--r-md);background:var(--surface)}
.prods{width:100%;border-collapse:collapse;min-width:780px}
.prods thead th{background:var(--navy-soft);color:var(--navy);padding:9px 8px;font-size:10px;text-transform:uppercase;letter-spacing:1px;font-weight:700;text-align:right;border-bottom:1px solid var(--line)}
.prods thead th:first-child{text-align:left;padding-left:14px}
.prods thead th.center{text-align:center}
.prods tbody td{padding:8px 8px;border-bottom:1px solid var(--line-soft);font-size:13px;vertical-align:middle}
.prods tbody td:first-child{padding-left:14px}
.prods tbody tr:last-child td{border-bottom:none}
.prods tbody tr.off{opacity:.45}
.prods .check-cell{text-align:center;width:42px}
.prods .check-cell input{width:16px;height:16px;cursor:pointer;accent-color:var(--navy)}
.prods .prod-name{font-weight:700;color:var(--ink)}
.prods .prod-name .sub{display:block;font-size:11px;font-weight:500;color:var(--ink-soft);margin-top:1px}
.prods .carrier-toggle{display:inline-flex;border:1px solid var(--line);border-radius:var(--r-sm);overflow:hidden;background:var(--surface)}
.prods .carrier-toggle button{border:none;background:transparent;padding:3px 9px;cursor:pointer;font-size:11px;font-weight:700;color:var(--ink-soft);font-family:var(--font);transition:all .12s}
.prods .carrier-toggle button.active{background:var(--orange);color:#fff}
.prods .pct-cell input,.prods .prem-cell input,.prods .cm-cell input{width:78px;text-align:right;padding:5px 7px;font-family:var(--mono);font-size:12px;border:1px solid var(--line);border-radius:var(--r-sm);background:var(--surface)}
.prods .pct-cell input:focus,.prods .prem-cell input:focus,.prods .cm-cell input:focus{outline:none;border-color:var(--navy);box-shadow:0 0 0 2px var(--navy-soft)}
.prods .pct-cell,.prods .prem-cell,.prods .cm-cell,.prods .out-cell,.prods .out-yr-cell,.prods .carrier-cell{text-align:right;white-space:nowrap}
.prods .carrier-cell{text-align:center}
.prods .out-cell,.prods .out-yr-cell{font-family:var(--mono);font-weight:700;color:var(--ink);font-size:13px}
.prods .out-yr-cell{color:var(--ink-dim);font-weight:600;font-size:12px}
.prods tfoot td{background:var(--surface-warm);padding:10px 8px;font-size:12px;font-weight:700;color:var(--ink-dim);text-transform:uppercase;letter-spacing:0.5px;border-top:2px solid var(--line)}
.prods tfoot td.r{text-align:right;color:var(--navy);font-family:var(--mono);font-size:14px}
.prods tfoot td.r .yr{display:block;font-size:11px;color:var(--ink-soft);font-weight:600;margin-top:1px}

/* Grand */
.grand{background:linear-gradient(135deg,var(--navy) 0%,#003D8F 100%);color:#fff;border-radius:var(--r-lg);padding:22px 26px;margin-bottom:14px;box-shadow:var(--shadow-md)}
.grand-eye{font-size:11px;letter-spacing:1.8px;text-transform:uppercase;color:var(--orange);font-weight:700;margin-bottom:10px}
.grand-rows{display:flex;flex-direction:column;gap:5px}
.grand-row{display:flex;justify-content:space-between;align-items:baseline;font-size:13px;padding:3px 0}
.grand-row .k{color:rgba(255,255,255,0.78);font-weight:500}
.grand-row .v{font-family:var(--mono);font-weight:700;color:#fff}
.grand-row.total{margin-top:8px;padding-top:12px;border-top:1px solid rgba(255,255,255,0.2)}
.grand-row.total .k{color:#fff;font-weight:700;font-size:15px}
.grand-row.total .v{font-size:26px;letter-spacing:-0.8px}
.grand-row.annual{padding-top:4px}
.grand-row.annual .k{font-size:11px;color:rgba(255,255,255,0.6)}
.grand-row.annual .v{font-size:14px;color:rgba(255,255,255,0.85);font-weight:600}
.grand-row.ceiling .k{color:var(--orange);font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:1px}
.grand-row.ceiling .v{color:#fff;font-size:13px;opacity:0.9}

/* Matrix */
.matrix-wrap{overflow-x:auto;border:1px solid var(--line);border-radius:var(--r-md);margin-top:8px}
.matrix{width:100%;border-collapse:collapse;min-width:820px}
.matrix thead th{background:var(--navy);color:#fff;padding:9px 8px;font-size:10px;text-transform:uppercase;letter-spacing:1px;font-weight:700;text-align:right;border-right:1px solid rgba(255,255,255,0.12)}
.matrix thead th:first-child{text-align:left;padding-left:14px}
.matrix thead th:last-child{border-right:none}
.matrix thead th .smol{display:block;font-size:9px;font-weight:500;opacity:0.7;margin-top:2px;letter-spacing:0.5px;text-transform:none}
.matrix tbody td{padding:6px 8px;border-bottom:1px solid var(--line-soft);border-right:1px solid var(--line-soft);font-size:13px;vertical-align:middle}
.matrix tbody td:last-child{border-right:none}
.matrix tbody td:first-child{padding-left:14px}
.matrix tbody tr:last-child td{border-bottom:none}
.matrix .party-name{font-weight:700;color:var(--ink)}
.matrix .party-name .sub{display:block;font-size:10px;font-weight:500;color:var(--ink-soft);text-transform:uppercase;letter-spacing:0.6px;margin-top:1px}
.matrix tr.hierarchy .party-name{color:var(--purple)}
.matrix tr.hierarchy{background:rgba(90,79,117,0.04)}
.matrix .pct-cell{text-align:right}
.matrix .pct-cell .pct-input{width:54px;text-align:right;padding:4px 6px;font-family:var(--mono);font-size:12px;border:1px solid var(--line);border-radius:var(--r-sm);background:var(--surface)}
.matrix .pct-cell .pct-input:focus{outline:none;border-color:var(--orange);box-shadow:0 0 0 2px var(--orange-soft)}
.matrix .pct-cell .pct-suffix{color:var(--ink-soft);font-family:var(--mono);font-size:11px;margin-left:2px}
.matrix td.money{text-align:right;font-family:var(--mono);font-weight:700;color:var(--navy);background:var(--navy-soft)}
.matrix td.money .yr{display:block;font-size:10px;font-weight:500;color:var(--ink-soft);margin-top:1px}
.matrix tfoot td{background:var(--surface-warm);border-top:2px solid var(--line);padding:10px 8px;font-size:12px;font-weight:700;color:var(--ink-dim);text-transform:uppercase;letter-spacing:0.5px}
.matrix tfoot td.col-sum{text-align:right}
.matrix tfoot td.col-sum.warn{color:var(--amber)}
.matrix tfoot td.col-sum.err{color:var(--red)}
.matrix tfoot td.col-sum.ok{color:var(--green)}

/* Visual take-home bars */
.viz-wrap{margin-top:20px;padding:18px 20px;background:var(--surface-warm);border-radius:var(--r-md);border:1px solid var(--line)}
.viz-title{font-size:13px;font-weight:700;color:var(--navy);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:14px;display:flex;justify-content:space-between;align-items:baseline}
.viz-title .legend{display:flex;gap:14px;font-size:11px;font-weight:500;color:var(--ink-dim);text-transform:none;letter-spacing:0}
.viz-title .legend span{display:inline-flex;align-items:center;gap:5px}
.viz-title .legend span::before{content:'';display:inline-block;width:10px;height:10px;border-radius:2px}
.viz-title .legend .L-er::before{background:var(--teal)}
.viz-title .legend .L-aca::before{background:var(--green)}
.viz-title .legend .L-acaO::before{background:#84CC16}
.viz-title .legend .L-aflac::before{background:var(--orange)}
.viz-title .legend .L-other::before{background:var(--purple)}
.viz-bars{display:flex;flex-direction:column;gap:10px}
.viz-row{display:grid;grid-template-columns:130px 1fr 130px;align-items:center;gap:14px}
.viz-row .vname{font-size:12px;font-weight:700;color:var(--ink)}
.viz-row .vname .vbring{display:block;font-size:10px;font-weight:500;color:var(--ink-soft);text-transform:uppercase;letter-spacing:0.6px;margin-top:1px}
.viz-row .vtake{font-family:var(--mono);font-size:13px;font-weight:700;color:var(--navy);text-align:right}
.viz-row .vtake .yr{display:block;font-size:10px;color:var(--ink-soft);font-weight:500;margin-top:1px}
.viz-bar{display:flex;height:26px;border-radius:var(--r-sm);overflow:hidden;background:#FFF;border:1px solid var(--line)}
.viz-bar > div{height:100%;font-size:10px;font-weight:700;color:#fff;display:flex;align-items:center;justify-content:center;font-family:var(--mono);min-width:0;overflow:hidden;white-space:nowrap}
.viz-bar > div.er{background:var(--teal)}
.viz-bar > div.aca{background:var(--green)}
.viz-bar > div.acaO{background:#84CC16}
.viz-bar > div.aflac{background:var(--orange)}
.viz-bar > div.other{background:var(--purple)}

/* Enroller mode */
.enroller-mode{display:flex;align-items:center;gap:14px;padding:12px 16px;margin-top:16px;background:var(--surface-warm);border-radius:var(--r-md);border:1px solid var(--line);flex-wrap:wrap}
.enroller-mode .em-label{font-size:13px;font-weight:700;color:var(--ink)}
.enroller-mode .em-help{font-size:11.5px;color:var(--ink-soft);flex:1;line-height:1.45;min-width:200px}
.enroller-mode .em-input{display:flex;align-items:center;gap:6px}
.enroller-mode .em-input .input-prefix{width:140px}
.enroller-mode .em-row.hidden{display:none}

.toggle-group{display:inline-flex;border:1px solid var(--line);border-radius:var(--r-sm);overflow:hidden;background:var(--surface-warm)}
.toggle-btn{border:none;background:transparent;padding:6px 14px;cursor:pointer;font-size:12px;font-weight:600;color:var(--ink-dim);font-family:var(--font);transition:all .15s}
.toggle-btn.active{background:var(--navy);color:#fff}

.btn{padding:8px 16px;border-radius:var(--r-sm);font-family:var(--font);font-size:13px;font-weight:600;cursor:pointer;transition:all .15s;border:1px solid var(--line);background:var(--surface);color:var(--ink-dim)}
.btn:hover{border-color:var(--ink-dim);color:var(--ink)}
.btn-row{display:flex;gap:8px;margin-top:14px;flex-wrap:wrap}

.footnote{font-size:11px;color:var(--ink-soft);text-align:center;margin-top:24px;padding:0 12px;line-height:1.5}
.help-block{font-size:11.5px;color:var(--ink-dim);background:var(--amber-soft);padding:10px 14px;border-radius:var(--r-sm);margin-top:12px;line-height:1.5;border-left:3px solid var(--amber)}
.help-block strong{color:var(--ink);font-weight:700}

@media (max-width:760px){
  .picker-grid{grid-template-columns:1fr}
  .account-grid{grid-template-columns:1fr}
  .row{grid-template-columns:1fr 100px 140px;gap:8px;font-size:13px}
  .grand-row.total .v{font-size:22px}
  .viz-row{grid-template-columns:90px 1fr 100px;gap:8px}
}
</style>
</head>
<body>
<div class="wrap">

<div class="header">
  <div class="eye">OTB Solutions · Commission Tool v4</div>
  <h1>Commission & Allocation Calculator</h1>
  <p>Choose your operating scenario, model the revenue streams, and see how dollars flow to each party — Channel (GA), TPA, FMO, Broker, Enroller, plus Aflac hierarchy.</p>
</div>

<!-- STEP 1 · COMP MODEL -->
<div class="section">
  <div class="section-title"><h2>Step 1 · Compensation Model</h2></div>
  <div class="picker-grid">
    <button type="button" class="pick-card active" data-model="standard">
      <div class="pc-eye">Model A</div>
      <div class="pc-ttl">Standard</div>
      <div class="pc-dsc">5 parties · no Aflac hierarchy slice.</div>
    </button>
    <button type="button" class="pick-card" data-model="aflacDsc">
      <div class="pc-eye">Model B</div>
      <div class="pc-ttl">Aflac + DSC</div>
      <div class="pc-dsc">DSC slices Aflac comp.</div>
    </button>
    <button type="button" class="pick-card" data-model="aflacDscRsc">
      <div class="pc-eye">Model C</div>
      <div class="pc-ttl">Aflac + DSC + RSC</div>
      <div class="pc-dsc">Full Aflac hierarchy.</div>
    </button>
  </div>
</div>

<!-- STEP 2 · OPERATING SCENARIO -->
<div class="section">
  <div class="section-title"><h2>Step 2 · Operating Scenario — Who is Doing the Work</h2></div>
  <div class="picker-grid">
    <button type="button" class="pick-card scn-op" data-scnop="brokerLed">
      <div class="pc-eye">Scenario A</div>
      <div class="pc-ttl">Broker-Led</div>
      <div class="pc-dsc">Broker does everything: writes + enrolls. Aflac BL4 — broker takes ~95% of Aflac. GA gets small override, no DSC/RSC.</div>
    </button>
    <button type="button" class="pick-card scn-op active" data-scnop="brokerChannel">
      <div class="pc-eye">Scenario B · Default</div>
      <div class="pc-ttl">Broker + Channel</div>
      <div class="pc-dsc">Broker writes; Channel (GA) enrolls + trains. Aflac BL2/BL3. DSC + RSC paid; production stays with the market.</div>
    </button>
