  { k:'other',   label:'Other Carrier',     short:'Other' }
];

// ── PRODUCTS ────────────────────────────────────────────────────────
const PRODUCTS = [
  { k:'aflacSuite', label:'Aflac Suite',          desc:'Accident/Cancer/CI/Hospital · $840/holder/yr (1.4 pol × $600)', pct:45,   annualPrem:840,  carrier:'aflac' },
  { k:'permLife',   label:'Permanent Life',       desc:'Cash value, lifetime',                                            pct:58.5, annualPrem:3600, carrier:'aflac' },
  { k:'std',        label:'Short-Term Disability',desc:'Income replacement, short',                                       pct:60,   annualPrem:400,  carrier:'aflac' },
  { k:'ltd',        label:'Long-Term Disability', desc:'Income replacement, long',                                        pct:60,   annualPrem:400,  carrier:'aflac' },
  { k:'dental',     label:'Dental',               desc:'Voluntary',                                                       pct:25,   annualPrem:300,  carrier:'other' },
  { k:'vision',     label:'Vision',               desc:'Voluntary',                                                       pct:25,   annualPrem:120,  carrier:'other' },
  { k:'hospital',   label:'Hospital Indemnity',   desc:'Standalone',                                                      pct:45,   annualPrem:360,  carrier:'aflac' },
  { k:'cancer',     label:'Cancer',               desc:'Standalone',                                                      pct:70,   annualPrem:300,  carrier:'aflac' },
  { k:'ci',         label:'Critical Illness',     desc:'Standalone',                                                      pct:70,   annualPrem:300,  carrier:'aflac' },
  { k:'accident',   label:'Accident',             desc:'Standalone',                                                      pct:48,   annualPrem:216,  carrier:'aflac' }
];

// ── BOTTOM LINE (ceiling) RATES for the pool calc ─────────────────
// Channel One bottom-line product rates (full hierarchy combined) — used to compute the "Bottom Line Pool" metric.
const BOTTOM_LINE_PCT = {
  aflacSuite:57, permLife:90, std:50, ltd:50, dental:35, vision:30, hospital:46, cancer:60, ci:63, accident:50
};

// ── PRODUCT SCENARIOS ───────────────────────────────────────────────
const SCENARIOS = {
  blank:    { ee:25, acaPmpm:0,  acaOver:0,   erPepm:0,  pen:{ aflacSuite:0, permLife:0, std:0, ltd:0, dental:0, vision:0, hospital:0, cancer:0, ci:0, accident:0 } },
  aflacOnly:{ ee:25, acaPmpm:0,  acaOver:0,   erPepm:20, pen:{ aflacSuite:35, permLife:0, std:0, ltd:0, dental:0, vision:0, hospital:0, cancer:0, ci:0, accident:0 } },
  aflacPerm:{ ee:25, acaPmpm:0,  acaOver:0,   erPepm:20, pen:{ aflacSuite:40, permLife:25, std:0, ltd:0, dental:0, vision:0, hospital:0, cancer:0, ci:0, accident:0 } },
  allAnc:   { ee:25, acaPmpm:0,  acaOver:0,   erPepm:20, pen:{ aflacSuite:45, permLife:30, std:60, ltd:60, dental:0, vision:0, hospital:0, cancer:0, ci:0, accident:0 } },
  allBen:   { ee:25, acaPmpm:20, acaOver:3.9, erPepm:20, pen:{ aflacSuite:60, permLife:30, std:80, ltd:80, dental:50, vision:40, hospital:30, cancer:25, ci:25, accident:40 } }
};

// ── COMP MODELS (just decide who's at the table) ────────────────────
const MODELS = {
  standard:    { parties:['ga','tpa','fmo','broker','enroller'] },
  aflacDsc:    { parties:['ga','tpa','fmo','broker','enroller','dsc'] },
  aflacDscRsc: { parties:['ga','tpa','fmo','broker','enroller','dsc','rsc'] }
};

// ── OPERATING SCENARIOS · drive matrix defaults ────────────────────
// Returns matrix defaults given parties + BL package. PEPM column gets overlaid by tier rule.
const OPERATING_SCENARIOS = {
  brokerLed:     { name:'Broker-Led',       blDefault:'BL4', model:'standard',
    notes:'Broker does everything; almost no Aflac left for hierarchy.',
    base:{
      acaPmpm: { ga:5,  fmo:0, broker:65, enroller:30, dsc:0, rsc:0 },
      other:   { ga:5,  fmo:0, broker:90, enroller:5,  dsc:0, rsc:0 }
    }
  },
  brokerChannel: { name:'Broker + Channel', blDefault:'BL2', model:'aflacDscRsc',
    notes:'Broker writes, Channel (GA) trains/enrolls. DSC + RSC paid.',
    base:{
      acaPmpm: { ga:35, fmo:0, broker:55, enroller:10, dsc:0, rsc:0 },
      other:   { ga:25, fmo:0, broker:60, enroller:10, dsc:3, rsc:2 }
    }
  },
  aflacInternal: { name:'Aflac-Internal',   blDefault:'NONE', model:'aflacDscRsc',
    notes:'Aflac agent writes + enrolls. No broker. GA + FMO get Aflac overrides funded from DSC/RSC.',
    base:{
      acaPmpm: { ga:20, fmo:0, broker:0,  enroller:70, dsc:5,  rsc:5  },
      other:   { ga:15, fmo:0, broker:0,  enroller:60, dsc:15, rsc:10 }
    }
  }
};

// Aflac column defaults per BL package — blended from level tables (DSC L30, RSC L40)
// FMO matrix Aflac=0 always (FMO Aflac comp lives in the override row to avoid double-count).
// Reference (Cancer level breakdown, % of premium):
//   BL1: Agent 24%, Broker 5.9%, DSC 6.35%, RSC 3.65%, Director 4.6%  -> bottom ~52%
//   BL2: Agent 20%, Broker 8.1%, DSC 5.80%, RSC 3.00%, Director 4.6%
//   BL3: Agent 17%, Broker 9.9%, DSC 4.55%, RSC 2.50%, Director 4.6%
//   BL4: Agent 0%,  Broker 18.7%, DSC 0%,    RSC 0%,    Director 4.6%
// Translated to % of Aflac comp pool (broker share from comprehensive sheet: BL1~30, BL2~40, BL3~50, BL4~95):
const BL_AFLAC_DEFAULTS = {
  // Channel (GA) override is FIXED at 5% always. If Channel also acts as broker, bump Broker row.
  // If Channel also enrolls, bump Enroller row down to whatever the actual Aflac agent earns and
  // shift the rest to Channel. Defaults below assume Channel is just the GA, not wearing other hats.
  BL1:  { ga:5, fmo:0, broker:30, enroller:49, dsc:10, rsc:6 },
  BL2:  { ga:5, fmo:0, broker:40, enroller:41, dsc:9,  rsc:5 },
  BL3:  { ga:5, fmo:0, broker:50, enroller:34, dsc:7,  rsc:4 },
  BL4:  { ga:5, fmo:0, broker:90, enroller:5,  dsc:0,  rsc:0 },
  NONE: { ga:5, fmo:0, broker:0,  enroller:73, dsc:14, rsc:8 }
};
// (FMO Aflac slice flows through the FMO Override row, not this column.)

// ── STATE ───────────────────────────────────────────────────────────
let currentModel = 'standard';
let currentOpScn = 'brokerChannel';
let currentScenario = 'allAnc';
let currentBL = 'BL2';
let enrollerMode = 'pct';
let alloc = {};
const productState = {};
PRODUCTS.forEach(p => { productState[p.k] = { on:true, carrier:p.carrier, pen:0, prem:p.annualPrem, pct:p.pct }; });

const $ = id => document.getElementById(id);
const fmt0 = n => '$' + Math.round(n).toLocaleString();

// ── PEPM TIER RULE ──────────────────────────────────────────────────
// Returns { tpa, fmo, broker } as %s of the ER PEPM allocation.
function pepmTierShares(erPepm) {
  if (erPepm <= 0) return { tpa:0, fmo:0, broker:0, tpaDol:0, fmoDol:0, brokerDol:0 };
  const tpaDol = Math.min(10, erPepm);
  const fmoDol = Math.min(10, Math.max(0, erPepm - 10));
  const brokerDol = Math.max(0, erPepm - 20);
  const tpa = (tpaDol / erPepm) * 100;
  const fmo = (fmoDol / erPepm) * 100;
  const broker = (brokerDol / erPepm) * 100;
  return { tpa, fmo, broker, tpaDol, fmoDol, brokerDol };
}

// ── LOAD ALLOC DEFAULTS (driven by Operating Scenario + BL + PEPM rule) ──
function loadAllocDefaults() {
  const op = OPERATING_SCENARIOS[currentOpScn];
  const parties = MODELS[currentModel].parties;
  // PEPM column from tier rule
  const erPepm = parseFloat($('erPepm').value) || 0;
  const tier = pepmTierShares(erPepm);
  const ePepm = { ga:0, tpa:tier.tpa, fmo:tier.fmo, broker:tier.broker, enroller:0, dsc:0, rsc:0 };
  // ACA Override: 100% FMO always
  const eAcaOver = { ga:0, tpa:0, fmo:100, broker:0, enroller:0, dsc:0, rsc:0 };
  // Aflac column from BL package defaults (blended DSC/RSC reflecting Aflac level tables)
  const aflacRow = BL_AFLAC_DEFAULTS[currentBL] || BL_AFLAC_DEFAULTS.BL2;
  function pick(row) {
    const out = {};
    parties.forEach(p => { out[p] = row[p] !== undefined ? row[p] : 0; });
    return out;
  }
  alloc = {
    erPepm:  pick(ePepm),
    acaPmpm: pick(op.base.acaPmpm),
    acaOver: pick(eAcaOver),
    aflac:   pick(aflacRow),
    other:   pick(op.base.other)
  };
}

// ── RENDER MATRIX ───────────────────────────────────────────────────
function renderMatrix() {
  const parties = MODELS[currentModel].parties;
  const head = ['<th>Party</th>']
    .concat(STREAMS.map(s => `<th>${s.short}<span class="smol">${s.label}</span></th>`))
    .concat(['<th>$ / mo<span class="smol">$ / yr</span></th>']).join('');
  $('matrixHead').innerHTML = head;
  $('matrixBody').innerHTML = parties.map(k => {
    const p = PARTY_INFO[k];
    const hCls = p.hierarchy ? ' hierarchy' : '';
    const cells = STREAMS.map(s => {
      const v = alloc[s.k][k] !== undefined ? alloc[s.k][k] : 0;
      return `<td class="pct-cell"><input type="number" class="pct-input" data-cell="${s.k}_${k}" min="0" max="100" step="0.5" value="${v}"><span class="pct-suffix">%</span></td>`;
    }).join('');
    return `<tr class="party-row${hCls}" data-party="${k}"><td class="party-name">${p.label}<span class="sub">${p.brings}</span></td>${cells}<td class="money" data-take="${k}">$0<span class="yr">$0 / yr</span></td></tr>`;
  }).join('');
  const sumCells = STREAMS.map(s => `<td class="col-sum" data-colsum="${s.k}">0%</td>`).join('');
  $('matrixFoot').innerHTML = `<td>Column sum</td>${sumCells}<td class="money" id="matrixGrandFoot">$0</td>`;
  document.querySelectorAll('.pct-input').forEach(inp => {
    inp.addEventListener('input', () => {
      const [stream, party] = inp.dataset.cell.split('_');
      alloc[stream][party] = parseFloat(inp.value) || 0;
      recalc();
    });
  });
}

// ── RENDER PRODUCT TABLE ────────────────────────────────────────────
function renderProducts() {
  $('prodBody').innerHTML = PRODUCTS.map(p => {
    const s = productState[p.k];
    const isAflac = s.carrier === 'aflac';
    return `<tr class="prod-tr${s.on?'':' off'}" data-k="${p.k}">
      <td class="check-cell"><input type="checkbox" data-on="${p.k}" ${s.on?'checked':''}></td>
      <td class="prod-name">${p.label}<span class="sub">${p.desc}</span></td>
      <td class="carrier-cell"><div class="carrier-toggle"><button type="button" data-car="${p.k}_aflac" class="${isAflac?'active':''}">Aflac</button><button type="button" data-car="${p.k}_other" class="${isAflac?'':'active'}">Other</button></div></td>
      <td class="pct-cell"><input type="number" data-pen="${p.k}" min="0" max="100" step="1" value="${s.pen}"><span style="color:var(--ink-soft);font-family:var(--mono);font-size:11px">%</span></td>
      <td class="prem-cell"><span style="color:var(--ink-soft);font-family:var(--mono);font-size:11px">$</span> <input type="number" data-prem="${p.k}" min="0" max="100000" step="10" value="${s.prem}"></td>
      <td class="cm-cell"><input type="number" data-pct="${p.k}" min="0" max="200" step="0.5" value="${s.pct}"><span style="color:var(--ink-soft);font-family:var(--mono);font-size:11px">%</span></td>
      <td class="out-cell" data-out="${p.k}">$0</td>
      <td class="out-yr-cell" data-outyr="${p.k}">$0</td>
    </tr>`;
  }).join('');
  document.querySelectorAll('[data-on]').forEach(cb => cb.addEventListener('change', () => { productState[cb.dataset.on].on = cb.checked; cb.closest('tr').classList.toggle('off', !cb.checked); recalc(); }));
  document.querySelectorAll('[data-car]').forEach(b => b.addEventListener('click', () => {
    const [k, car] = b.dataset.car.split('_'); productState[k].carrier = car;
    b.parentNode.querySelectorAll('button').forEach(x => x.classList.remove('active')); b.classList.add('active'); recalc();
  }));
  ['pen','prem','pct'].forEach(field => {
    document.querySelectorAll(`[data-${field}]`).forEach(i => i.addEventListener('input', () => { productState[i.dataset[field]][field === 'pen' ? 'pen' : field === 'prem' ? 'prem' : 'pct'] = parseFloat(i.value) || 0; recalc(); }));
  });
}

// ── PEPM BAR VIZ ────────────────────────────────────────────────────
function renderPepmBar() {
  const erPepm = parseFloat($('erPepm').value) || 0;
  const t = pepmTierShares(erPepm);
  const bar = $('pepmBar');
  if (erPepm <= 0) {
    bar.innerHTML = '<div class="empty" style="flex:1">No PEPM</div>';
    return;
  }
  const segs = [];
  if (t.tpaDol > 0) segs.push(`<div class="tpa" style="flex:${t.tpaDol}">TPA $${t.tpaDol.toFixed(2)}</div>`);
  if (t.fmoDol > 0) segs.push(`<div class="fmo" style="flex:${t.fmoDol}">FMO $${t.fmoDol.toFixed(2)}</div>`);
  if (t.brokerDol > 0) segs.push(`<div class="broker" style="flex:${t.brokerDol}">Broker $${t.brokerDol.toFixed(2)}</div>`);
  bar.innerHTML = segs.join('');
}

// ── APPLY SCENARIO PRESET ──────────────────────────────────────────
function applyProductScenario(name) {
  currentScenario = name;
  const s = SCENARIOS[name];
  if (!s) return;
  $('ee').value = s.ee;
  $('erPepm').value = s.erPepm;
  $('acaPmpm').value = s.acaPmpm;
  $('acaOver').value = s.acaOver;
  PRODUCTS.forEach(p => {
    const pen = s.pen[p.k] !== undefined ? s.pen[p.k] : 0;
    productState[p.k].pen = pen;
    productState[p.k].on = pen > 0;
    productState[p.k].prem = p.annualPrem;
    productState[p.k].pct = p.pct;
    productState[p.k].carrier = p.carrier;
  });
  renderProducts();
  document.querySelectorAll('[data-scn]').forEach(b => b.classList.toggle('active', b.dataset.scn === name));
  loadAllocDefaults();
  renderMatrix();
  recalc();
}

// ── APPLY OPERATING SCENARIO ────────────────────────────────────────
function applyOperatingScenario(name) {
  currentOpScn = name;
  document.querySelectorAll('[data-scnop]').forEach(b => b.classList.toggle('active', b.dataset.scnop === name));
  const op = OPERATING_SCENARIOS[name];
  // Force comp model to whatever this op scenario expects (e.g. Aflac+DSC+RSC for Channel)
  currentModel = op.model;
  document.querySelectorAll('[data-model]').forEach(c => c.classList.toggle('active', c.dataset.model === currentModel));
  // Set BL default
  currentBL = op.blDefault;
  applyBL(currentBL, /*skipRecalc*/ true);
  loadAllocDefaults();
  renderMatrix();
  recalc();
}

// ── APPLY BL PACKAGE ────────────────────────────────────────────────
function applyBL(bl, skipRecalc) {
  currentBL = bl;
  document.querySelectorAll('[data-bl]').forEach(b => b.classList.toggle('active', b.dataset.bl === bl));
  const meta = {
    BL1:'BL1 — Broker 30% / Enroller 49% / DSC 10% / RSC 6% / Channel 5%.',
    BL2:'BL2 — Broker 40% / Enroller 41% / DSC 9% / RSC 5% / Channel 5%. Balanced default.',
    BL3:'BL3 — Broker 50% / Enroller 34% / DSC 7% / RSC 4% / Channel 5%.',
    BL4:'BL4 — Broker 90% / Enroller 5% / DSC + RSC zeroed / Channel 5%.',
    NONE:'No broker — Enroller (Aflac agent) 73% / DSC 14% / RSC 8% / Channel 5%.'
  };
  $('blMeta').textContent = meta[bl] || '';
  // Reload the Aflac column from BL defaults (skip if init suppressed)
  if (!skipRecalc) {
    const parties = MODELS[currentModel].parties;
    const row = BL_AFLAC_DEFAULTS[bl] || BL_AFLAC_DEFAULTS.BL2;
    parties.forEach(p => { alloc.aflac[p] = row[p] !== undefined ? row[p] : 0; });
    renderMatrix();
    recalc();
  }
}

// ── CALC ────────────────────────────────────────────────────────────
function recalc() {
  const ee = parseFloat($('ee').value) || 0;
  const dep = parseFloat($('depFactor').value) || 0;
  const members = ee * dep;
  $('totalMembers').textContent = Math.round(members * 10) / 10;

  const erPepm = parseFloat($('erPepm').value) || 0;
  const acaPmpm = parseFloat($('acaPmpm').value) || 0;
  const acaOver = parseFloat($('acaOver').value) || 0;
  const erPepmMo = ee * erPepm;
  const acaPmpmMo = members * acaPmpm;
  const acaOverMo = members * acaOver;

  $('erPepmOut').innerHTML  = fmt0(erPepmMo)  + '<span class="yr">' + fmt0(erPepmMo*12)  + ' / yr</span>';
  $('acaPmpmOut').innerHTML = fmt0(acaPmpmMo) + '<span class="yr">' + fmt0(acaPmpmMo*12) + ' / yr</span>';
  $('acaOverOut').innerHTML = fmt0(acaOverMo) + '<span class="yr">' + fmt0(acaOverMo*12) + ' / yr</span>';
  renderPepmBar();

  let aflacMo = 0, otherMo = 0, ceilingMo = 0;
  PRODUCTS.forEach(p => {
    const s = productState[p.k];
    let mo = 0, ceilMo = 0;
    if (s.on) {
      mo = ee * (s.pen/100) * s.prem * (s.pct/100) / 12;
      // Ceiling uses bottom-line full rate at user's premium + penetration
      const bottomPct = BOTTOM_LINE_PCT[p.k] || s.pct;
      ceilMo = ee * (s.pen/100) * s.prem * (bottomPct/100) / 12;
    }
    const outEl = document.querySelector(`[data-out="${p.k}"]`);
    const outYrEl = document.querySelector(`[data-outyr="${p.k}"]`);
    if (outEl) { outEl.textContent = fmt0(mo); }
    if (outYrEl) { outYrEl.textContent = fmt0(mo*12); }
    if (s.on) {
      if (s.carrier === 'aflac') aflacMo += mo; else otherMo += mo;
      ceilingMo += ceilMo;
    }
  });
  $('aflacSub').innerHTML = fmt0(aflacMo) + '<span class="yr">' + fmt0(aflacMo*12) + ' / yr</span>';
  $('otherSub').innerHTML = fmt0(otherMo) + '<span class="yr">' + fmt0(otherMo*12) + ' / yr</span>';
  const prodTotal = aflacMo + otherMo;
  $('prodTotal').innerHTML = fmt0(prodTotal) + '<span class="yr">' + fmt0(prodTotal*12) + ' / yr</span>';

  // FMO Aflac override (separate from matrix — adds straight to FMO take)
  const fmoAflacPct = parseFloat($('fmoAflacPct').value) || 0;
  const fmoAflacBonus = parseFloat($('fmoAflacBonus').value) || 0;
  const fmoOverrideMo = aflacMo * (fmoAflacPct/100) + fmoAflacBonus;
  $('fmoAflacOut').innerHTML = fmt0(fmoOverrideMo) + '<span class="yr">' + fmt0(fmoOverrideMo*12) + ' / yr</span>';

  const monthly = erPepmMo + acaPmpmMo + acaOverMo + aflacMo + otherMo;
  const annual = monthly * 12;
  const ceiling = (erPepmMo + acaPmpmMo + acaOverMo + ceilingMo);
  $('streamsTotal').textContent = fmt0(monthly) + ' / mo';
  $('gtEr').textContent = fmt0(erPepmMo);
  $('gtAca').textContent = fmt0(acaPmpmMo);
  $('gtAcaOver').textContent = fmt0(acaOverMo);
  $('gtAflac').textContent = fmt0(aflacMo);
  $('gtOther').textContent = fmt0(otherMo);
  $('gtMo').textContent = fmt0(monthly);
  $('gtYr').textContent = fmt0(annual) + ' / yr';
  $('gtCeiling').textContent = fmt0(ceiling * 12) + ' / yr';
  $('matrixGrand').textContent = fmt0(monthly);

  // ── ALLOCATION ──
  const parties = MODELS[currentModel].parties;
  const streamAmounts = { erPepm:erPepmMo, acaPmpm:acaPmpmMo, acaOver:acaOverMo, aflac:aflacMo, other:otherMo };
  const partyTake = {};
  const partyByStream = {};
  parties.forEach(p => { partyTake[p] = 0; partyByStream[p] = { erPepm:0, acaPmpm:0, acaOver:0, aflac:0, other:0 }; });

  const usePctEnroller = (enrollerMode === 'pct');

  STREAMS.forEach(s => {
    let colSum = 0;
    parties.forEach(p => {
      let pct = alloc[s.k][p] !== undefined ? alloc[s.k][p] : 0;
      let effPct = pct;
      if (!usePctEnroller && p === 'enroller') effPct = 0;
      const dollars = streamAmounts[s.k] * (effPct / 100);
      partyTake[p] += dollars;
      partyByStream[p][s.k] = dollars;
      colSum += pct;
    });
    const cs = document.querySelector(`[data-colsum="${s.k}"]`);
    if (cs) {
      const r = Math.round(colSum * 10) / 10;
      cs.textContent = r + '%';
      cs.classList.remove('warn','err','ok');
      if (Math.abs(r - 100) < 0.05) cs.classList.add('ok');
      else if (Math.abs(r - 100) <= 5) cs.classList.add('warn');
      else cs.classList.add('err');
    }
  });

  // Add FMO Aflac override on top
  if (partyTake.fmo !== undefined) {
    partyTake.fmo += fmoOverrideMo;
    partyByStream.fmo.aflac += fmoOverrideMo;
  }
  // Per-diem on top for enroller
  if (!usePctEnroller && partyTake.enroller !== undefined) {
    const diem = parseFloat($('enrDiem').value) || 0;
    partyTake.enroller += diem;
  }

  let totalTake = 0;
  parties.forEach(p => {
    const el = document.querySelector(`[data-take="${p}"]`);
    if (el) el.innerHTML = fmt0(partyTake[p]) + '<span class="yr">' + fmt0(partyTake[p]*12) + ' / yr</span>';
    totalTake += partyTake[p];
  });
  const ft = $('matrixGrandFoot');
  if (ft) ft.textContent = fmt0(totalTake);

  // ── VIZ ──
  renderViz(parties, partyByStream, partyTake);
}

// ── VIZ ─────────────────────────────────────────────────────────────
function renderViz(parties, byStream, takes) {
  const maxTake = Math.max(0.0001, ...parties.map(p => takes[p]));
  $('vizBars').innerHTML = parties.map(p => {
    const t = takes[p];
    const widthPct = (t / maxTake) * 100;
    const parts = byStream[p];
    const segTotal = (parts.erPepm + parts.acaPmpm + parts.acaOver + parts.aflac + parts.other) || 1;
    const seg = (v, cls) => v > 0 ? `<div class="${cls}" style="flex:${v}">${v >= segTotal*0.10 ? fmt0(v) : ''}</div>` : '';
    return `<div class="viz-row">
      <div class="vname">${PARTY_INFO[p].label}<span class="vbring">${PARTY_INFO[p].brings}</span></div>
      <div class="viz-bar" style="width:${widthPct}%">
        ${seg(parts.erPepm,'er')}${seg(parts.acaPmpm,'aca')}${seg(parts.acaOver,'acaO')}${seg(parts.aflac,'aflac')}${seg(parts.other,'other')}
      </div>
      <div class="vtake">${fmt0(t)}<span class="yr">${fmt0(t*12)} / yr</span></div>
    </div>`;
  }).join('');
}

// ── EVENTS ──────────────────────────────────────────────────────────
document.querySelectorAll('[data-model]').forEach(c => c.addEventListener('click', () => {
  document.querySelectorAll('[data-model]').forEach(x => x.classList.remove('active'));
  c.classList.add('active');
  currentModel = c.dataset.model;
  loadAllocDefaults();
  renderMatrix();
  recalc();
}));
document.querySelectorAll('[data-scnop]').forEach(b => b.addEventListener('click', () => applyOperatingScenario(b.dataset.scnop)));
document.querySelectorAll('[data-scn]').forEach(b => b.addEventListener('click', () => applyProductScenario(b.dataset.scn)));
document.querySelectorAll('[data-bl]').forEach(b => b.addEventListener('click', () => applyBL(b.dataset.bl)));

$('enrModePct').addEventListener('click', () => setEnrMode('pct'));
$('enrModeDiem').addEventListener('click', () => setEnrMode('diem'));
function setEnrMode(mode) {
  enrollerMode = mode;
  $('enrModePct').classList.toggle('active', mode === 'pct');
  $('enrModeDiem').classList.toggle('active', mode === 'diem');
  $('enrDiemRow').classList.toggle('hidden', mode !== 'diem');
  $('enrollerHelp').textContent = mode === 'pct' ? '% of streams — enroller takes a slice from each stream\'s column.' : 'Per-diem — enroller paid a fixed $/mo on top; % shares zeroed for take-home.';
  recalc();
}

$('resetDefaultsBtn').addEventListener('click', () => { loadAllocDefaults(); renderMatrix(); recalc(); });
$('normalizeBtn').addEventListener('click', () => {
  const parties = MODELS[currentModel].parties;
  STREAMS.forEach(s => {
    const sum = parties.reduce((a,p) => a + (alloc[s.k][p] || 0), 0);
    if (sum > 0) parties.forEach(p => { alloc[s.k][p] = Math.round(((alloc[s.k][p] || 0) / sum) * 1000) / 10; });
  });
  renderMatrix(); recalc();
});

['ee','depFactor','erPepm','acaPmpm','acaOver','enrDiem','fmoAflacPct','fmoAflacBonus'].forEach(id => {
  const el = $(id);
  if (el) el.addEventListener('input', () => {
    if (id === 'erPepm') { loadAllocDefaults(); renderMatrix(); }
    recalc();
  });
});

// ── INIT ────────────────────────────────────────────────────────────
applyOperatingScenario('brokerChannel');
applyProductScenario('allAnc');
renderProducts();
renderPepmBar();
recalc();
</script>
</body>
</html>
