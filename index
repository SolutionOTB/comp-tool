  rsc:      { label:'RSC',          brings:'Aflac hierarchy (Level 40)', hierarchy:true }
};

const STREAMS = [
  { k:'erPepm',  label:'ER ICHRA PEPM',     short:'ER PEPM' },
  { k:'acaPmpm', label:'ACA PMPM',          short:'ACA PMPM' },
  { k:'acaOver', label:'ACA Override',      short:'ACA OVR' },
